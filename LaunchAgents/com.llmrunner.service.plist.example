<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.llmrunner.service</string>

  <key>ProgramArguments</key>
  <array>
    <string>/Applications/LLMRunner.app/Contents/MacOS/llmrunner</string>
    <string>--config</string>
    <string>/Users/YOU/.llmrunner/config.json</string>
  </array>

  <key>RunAtLoad</key>
  <true/>

  <key>KeepAlive</key>
  <true/>

  <key>StandardOutPath</key>
  <string>/Users/YOU/Library/Logs/llmrunner.log</string>

  <key>StandardErrorPath</key>
  <string>/Users/YOU/Library/Logs/llmrunner.err.log</string>
</dict>
</plist>
